{
    "name": "happones/laravel-vue-i18n-generator",
    "license": "MIT",
    "description": "Generates a vue-i18n compatible include file from your Laravel translations.",
    "keywords": [
        "laravel",
        "vue-i18n"
    ],
    "homepage": "http://github.com/happones/laravel-vue-i18n-generator",
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/happones"
        },
        {
            "type": "patreon",
            "url": "https://www.patreon.com/happones"
        },
        {
            "type": "ko-fi",
            "url": "https://ko-fi.com/happones"
        },
        {
            "type": "custom",
            "url": "https://www.buymeacoffee.com/happones"
        }
    ],
    "authors": [
        {
            "name": "Omar Hernandez",
            "email": "root@happones.net"
        }
    ],
    "require": {
        "php": "^8.3.0",
        "ext-json": "*",
        "ext-mbstring": "*",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Happones\\VueInternationalizationGenerator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Happones\\VueInternationalizationGenerator\\GeneratorProvider"
            ]
        }
    }
}